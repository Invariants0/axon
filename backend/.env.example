# AXON backend environment example
# Core
APP_NAME=AXON
ENV=development
TEST_MODE=true

# AI providers (used in mock/non-real mode)t-4.1-mini
GRADIENT_MODEL=gpt-4.1-mini
GRADIENT_BASE_URL=https://api.digitalocean.com/v2/ai
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# Fallback providers (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# Storage
# In production/cloud, set DATABASE_URL to your managed Postgres instance.
# Example (DigitalOcean):
# DATABASE_URL=postgresql+asyncpg://doadmin:<password>@<host>:<port>/<db>?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/axon
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DB_PATH=.chroma

# Vector Database Provider Selection
# Options: "chroma" (default), "qdrant"
VECTOR_DB_PROVIDER=chroma
EMBEDDING_DIMENSION=384

# Qdrant Cloud Configuration (optional, for Qdrant provider)
# Get from Qdrant Cloud: https://cloud.qdrant.io/
# QDRANT_URL=https://YOUR_CLUSTER_ID.eu-west-1-0.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=YOUR_API_KEY
# QDRANT_COLLECTION=axon_memory

# API
CORS_ORIGINS=["http://localhost:3000"]
RATE_LIMIT_PER_MIN=120

# Runtime mode
# Options: gradient, real, mock, gemini
# - gradient: DigitalOcean AI Inference with glm-5 (RECOMMENDED FOR PRODUCTION)
# - real: Full ADK agent mode with DigitalOcean agents
# - mock: Test mode with deterministic responses
# - gemini: Google Gemini API (fallback for testing)
AXON_MODE=gradient
LOG_LEVEL=INFO
LOG_JSON=false

# Hackathon Security & Testing
AXON_API_KEY=
AXON_DEBUG_PIPELINE=true
SKILL_EXECUTION_TIMEOUT=20

# PHASE-2: Concurrency tuning (defaults: backward compatible single worker)
AXON_WORKER_COUNT=1

# DigitalOcean Agent Deployment (for AXON_MODE=real)
DIGITALOCEAN_API_TOKEN=
AXON_AGENT_TIMEOUT=120
AXON_PLANNER_AGENT_URL=
AXON_RESEARCH_AGENT_URL=
AXON_REASONING_AGENT_URL=
AXON_BUILDER_AGENT_URL=

# PHASE-3: Distributed Infrastructure
# Task Queue Backend: inmemory (default, single-process) or redis (distributed)
AXON_QUEUE_BACKEND=inmemory

# Redis configuration (only needed if AXON_QUEUE_BACKEND=redis or AXON_BREAKER_BACKEND=redis)
AXON_REDIS_URL=redis://redis:6379
AXON_REDIS_QUEUE_NAME=axon:tasks

# Circuit Breaker Backend: memory (default, single-process) or redis (distributed)
AXON_BREAKER_BACKEND=memory
