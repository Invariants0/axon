# AXON backend environment example
# Core
APP_NAME=AXON
ENV=development
TEST_MODE=true
API_KEY=

# AI providers (used in mock/non-real mode)
GRADIENT_API_KEY=
GRADIENT_MODEL=gpt-4.1-mini
GRADIENT_BASE_URL=https://api.digitalocean.com/v2/ai
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# Gemini (for hackathon testing)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Storage
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/axon
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DB_PATH=.chroma

# API
CORS_ORIGINS=["http://localhost:3000"]
RATE_LIMIT_PER_MIN=120

# Runtime mode
AXON_MODE=gemini
LOG_LEVEL=INFO
LOG_JSON=false

# Hackathon Security & Testing
AXON_API_KEY=
AXON_DEBUG_PIPELINE=true
SKILL_EXECUTION_TIMEOUT=20

# PHASE-2: Concurrency tuning (defaults: backward compatible single worker)
AXON_WORKER_COUNT=1

# DigitalOcean / Gradient agent mode
DIGITALOCEAN_API_TOKEN=
GRADIENT_MODEL_ACCESS_KEY=
DIGITALOCEAN_KB_UUID=
AXON_AGENT_TIMEOUT=120
AXON_PLANNER_AGENT_URL=
AXON_RESEARCH_AGENT_URL=
AXON_REASONING_AGENT_URL=
AXON_BUILDER_AGENT_URL=

# PHASE-3: Distributed Infrastructure
# Task Queue Backend: inmemory (default, single-process) or redis (distributed)
AXON_QUEUE_BACKEND=inmemory

# Redis configuration (only needed if AXON_QUEUE_BACKEND=redis or AXON_BREAKER_BACKEND=redis)
AXON_REDIS_URL=redis://localhost:6379
AXON_REDIS_QUEUE_NAME=axon:tasks

# Circuit Breaker Backend: memory (default, single-process) or redis (distributed)
AXON_BREAKER_BACKEND=memory
